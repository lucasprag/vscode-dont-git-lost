{
  "name": "dont-git-lost",
  "displayName": "Don't Git Lost",
  "icon": "icon.png",
  "description": "Step through any file's history in the editor. Subdued blame, rich hover, lightweight.",
  "version": "0.1.0",
  "publisher": "lucasprag",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucasprag/vscode-dont-git-lost"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["SCM Providers", "Other"],
  "keywords": ["git", "blame", "history", "lightweight", "gitlens-alternative"],
  "main": "./dist/extension.js",
  "extensionDependencies": ["vscode.git"],
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      { "command": "dontgitlost.timeTravel.back", "title": "Don't Git Lost: Previous Version (Overlay)", "icon": "$(arrow-left)" },
      { "command": "dontgitlost.timeTravel.backWithDiff", "title": "Don't Git Lost: Previous Version (Diff Editor)", "icon": "$(chevron-left)" },
      { "command": "dontgitlost.timeTravel.forwardWithDiff", "title": "Don't Git Lost: Next Version (Diff Editor)", "icon": "$(chevron-right)" },
      { "command": "dontgitlost.timeTravel.forward", "title": "Don't Git Lost: Next Version (Overlay)", "icon": "$(arrow-right)" },
      { "command": "dontgitlost.timeTravel.returnToHead", "title": "Don't Git Lost: Return to HEAD", "icon": "$(home)" },
      { "command": "dontgitlost.copySha", "title": "Don't Git Lost: Copy SHA" },
      { "command": "dontgitlost.openUrl", "title": "Don't Git Lost: Open URL" },
      { "command": "dontgitlost.signInGithub", "title": "Don't Git Lost: Sign in to GitHub" }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "dontgitlost.timeTravel.back",
          "group": "navigation@1",
          "when": "dontgitlost:hasGitHistory && (resourceScheme == file || resourceScheme == dont-git-lost)"
        },
        {
          "command": "dontgitlost.timeTravel.backWithDiff",
          "group": "navigation@2",
          "when": "dontgitlost:hasGitHistory && (resourceScheme == file || resourceScheme == dont-git-lost)"
        },
        {
          "command": "dontgitlost.timeTravel.forwardWithDiff",
          "group": "navigation@3",
          "when": "dontgitlost:hasGitHistory && dontgitlost:canGoForward"
        },
        {
          "command": "dontgitlost.timeTravel.forward",
          "group": "navigation@4",
          "when": "dontgitlost:hasGitHistory && dontgitlost:canGoForward"
        },
        {
          "command": "dontgitlost.timeTravel.returnToHead",
          "group": "navigation@5",
          "when": "resourceScheme == dont-git-lost"
        }
      ]
    },
    "configuration": {
      "title": "Don't Git Lost",
      "properties": {
        "dontgitlost.blame.enabled": {
          "type": "boolean", "default": true,
          "description": "Show the inline blame annotation on the current line."
        },
        "dontgitlost.blame.format": {
          "type": "string", "default": "${author}, ${ago} • ${message}",
          "description": "Annotation template. Tokens: ${author}, ${ago}, ${date}, ${sha}, ${message}, ${pr}."
        },
        "dontgitlost.blame.messageMaxLength": {
          "type": "number", "default": 80,
          "description": "Maximum number of characters of the commit message shown inline."
        },
        "dontgitlost.timeTravel.enabled": {
          "type": "boolean", "default": true,
          "description": "Show back/forward buttons in the editor toolbar to step through file history."
        },
        "dontgitlost.host.gitlabToken": {
          "type": "string", "default": "",
          "markdownDescription": "Personal access token for GitLab (scope: `read_api`). [Create one](https://gitlab.com/-/profile/personal_access_tokens)."
        },
        "dontgitlost.host.bitbucketToken": {
          "type": "string", "default": "",
          "markdownDescription": "App password for Bitbucket (scopes: `account:read`, `pullrequest:read`). [Create one](https://bitbucket.org/account/settings/app-passwords/)."
        },
        "dontgitlost.host.selfHosted": {
          "type": "object", "default": {},
          "description": "Self-hosted host overrides, e.g. {\"git.company.com\": {\"type\": \"gitlab\", \"baseUrl\": \"https://git.company.com/api/v4\"}}."
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package",
    "vscode:prepublish": "node build.mjs --production"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.0",
    "lru-cache": "^10.2.0"
  }
}
